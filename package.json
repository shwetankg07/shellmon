{
  "name": "shellmon",
  "version": "3.2.0",
  "description": "A terminal pet that feeds on your dev activity — any test runner, any build, any command. Species, live watch mode, achievements, themes. Zero dependencies.",
  "type": "module",
  "bin": {
    "shellmon": "cli.mjs"
  },
  "files": [
    "cli.mjs"
  ],
  "scripts": {
    "start": "node cli.mjs",
    "test": "node --test && bash test/shell-integration.sh",
    "test:unit": "node --test",
    "test:shell": "bash test/shell-integration.sh",
    "pub": "npm test && npm publish"
  },
  "keywords": [
    "cli",
    "terminal",
    "pet",
    "tamagotchi",
    "tui",
    "git",
    "git-hook",
    "prompt",
    "productivity",
    "achievements",
    "themes",
    "zero-dependency"
  ],

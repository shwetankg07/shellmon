  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shwetankg07/shellmon.git"
  },
  "homepage": "https://github.com/shwetankg07/shellmon#readme",
